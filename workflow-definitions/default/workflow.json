      "kind": "Join",
      "displayName": "Cross-Functional Review Join",
      "forkId": "review-fork",
      "next": "master-reviewer"
    },
    {
      "id": "master-reviewer",
      "kind": "Stage",
      "displayName": "Master Review",
      "role": "Review",
      "agent": "master-reviewer",
      "models": [
        "gpt-5.4"
      ],
      "reasoningEffort": "highest-supported",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo",
        "node:development-amigo",
        "node:testing-amigo",
        "node:builder",
        "node:solution-architect-reviewer",
        "node:principal-engineer-reviewer",
        "node:devops-engineer-reviewer",
        "node:platform-engineer-reviewer",
        "node:developer-evangelist-reviewer",
        "node:ux-designer-reviewer",
        "node:rebuilder"
      ],
      "outputs": [
        "reviewVerdict",
        "reviewFindings"
      ],
      "customMessage": "Combine every specialist review into one master review. Deduplicate overlapping findings, preserve important disagreements, and produce one clear approval decision plus one consolidated set of builder instructions.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/master-reviewer.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/master-reviewer.rules.md"
        }
      ],
      "next": "review-decision"
    },
    {
      "id": "review-decision",
      "kind": "Decision",
      "displayName": "Review Decision",
      "role": "Decision",
      "agent": "decision",
      "models": [
        "gpt-5.4"
      ],
      "reasoningEffort": "highest-supported",
      "decisionMode": "Rules",
      "ruleSet": "clean-agile-review",
      "decisionSourceNodeId": "master-reviewer",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo",
        "node:development-amigo",
        "node:testing-amigo",
        "node:builder",
        "node:master-reviewer",
        "node:rebuilder"
      ],
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/decision.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/decision.rules.md"
        }
      ],
      "choices": [
        {
          "id": "approve",
          "displayName": "Approve",
          "nextNodeId": "approved"
        },
        {
          "id": "rebuild",
          "displayName": "Rebuild",
          "nextNodeId": "rebuilder"
        },
        {
          "id": "stop",
          "displayName": "Stop",
          "nextNodeId": "stopped"
        }
      ]
    },
    {
      "id": "rebuilder",
      "kind": "Stage",
      "displayName": "Focused Rework",
      "role": "Rework",
      "agent": "rebuilder",
      "models": [
        "gpt-5.4"
      ],
      "reasoningEffort": "highest-supported",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo",
        "node:development-amigo",
        "node:testing-amigo",
        "node:builder",
        "node:github-poll",
        "node:master-reviewer",
        "node:rebuilder"
      ],
      "outputs": [
        "reworkSummary",
        "updatedValidation"
      ],
      "customMessage": "Apply the smallest effective correction set needed to resolve review findings while preserving valid work and maintaining technical quality.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/rebuilder.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/rebuilder.rules.md"
        }
      ],
      "next": "github-sync"
    },
    {
      "id": "approved",
      "kind": "Exit",
      "displayName": "Approved Exit",
      "exitStatus": "Approved"
    },
    {
      "id": "stopped",
      "kind": "Exit",
      "displayName": "Stopped Exit",
      "exitStatus": "Stopped"
    }
  ],
  "policy": {
    "decisionMode": "Rules",
    "maxReviewCycles": 2,
    "maxRebuilds": 1,
    "maxParallelism": 6,
    "maxNodeVisits": 20
  }
}
