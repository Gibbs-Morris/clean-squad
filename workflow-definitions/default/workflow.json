{
  "version": "2.1",
  "name": "Clean Agile Default Workflow",
  "defaultEntryPoint": "default",
  "entryPoints": [
    {
      "id": "default",
      "nodeId": "increment-framing"
    },
    {
      "id": "planning",
      "nodeId": "increment-framing"
    },
    {
      "id": "three-amigos",
      "nodeId": "three-amigos-fork"
    },
    {
      "id": "research",
      "nodeId": "three-amigos-fork"
    },
    {
      "id": "build",
      "nodeId": "builder"
    },
    {
      "id": "review",
      "nodeId": "review-fork"
    }
  ],
  "sharedAssets": [
    {
      "kind": "theory",
      "path": "instructions/general/clean-agile.instructions.md"
    },
    {
      "kind": "theory",
      "path": "instructions/general/first-principles-thinking.instructions.md"
    },
    {
      "kind": "theory",
      "path": "instructions/general/chain-of-verification.instructions.md"
    },
    {
      "kind": "repository-instruction",
      "path": "instructions/repository/build-and-test.instructions.md"
    },
    {
      "kind": "repository-instruction",
      "path": "instructions/repository/repository-structure.instructions.md"
    },
    {
      "kind": "workflow-rule",
      "path": "rules/workflow/clean-agile.rules.md"
    },
    {
      "kind": "workflow-rule",
      "path": "rules/workflow/shared.rules.md"
    },
    {
      "kind": "workflow-rule",
      "path": "rules/workflow/repository-quality.rules.md"
    }
  ],
  "nodes": [
    {
      "id": "increment-framing",
      "kind": "Stage",
      "displayName": "Increment Framing",
      "role": "Planning",
      "agent": "planner",
      "inputs": [
        "request"
      ],
      "outputs": [
        "incrementFrame",
        "acceptanceSignals",
        "scopeGuardrails"
      ],
      "customMessage": "Frame the request as the smallest valuable increment that can be built and verified safely before implementation begins.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/planner.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/planner.rules.md"
        }
      ],
      "next": "three-amigos-fork"
    },
    {
      "id": "three-amigos-fork",
      "kind": "Fork",
      "displayName": "Three Amigos Fork",
      "joinNodeId": "three-amigos-join",
      "branches": [
        {
          "id": "business",
          "nextNodeId": "business-amigo"
        },
        {
          "id": "development",
          "nextNodeId": "development-amigo"
        },
        {
          "id": "testing",
          "nextNodeId": "testing-amigo"
        }
      ]
    },
    {
      "id": "business-amigo",
      "kind": "Stage",
      "displayName": "Business Amigo",
      "role": "Business",
      "agent": "business-amigo",
      "inputs": [
        "request",
        "node:increment-framing"
      ],
      "outputs": [
        "businessOutcome",
        "acceptanceExamples"
      ],
      "customMessage": "Represent the business perspective by clarifying value, user outcomes, examples, and what done should mean for this increment.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/business-amigo.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/business-amigo.rules.md"
        }
      ],
      "next": "three-amigos-join"
    },
    {
      "id": "development-amigo",
      "kind": "Stage",
      "displayName": "Development Amigo",
      "role": "Development",
      "agent": "development-amigo",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo"
      ],
      "outputs": [
        "technicalApproach",
        "technicalRisks"
      ],
      "customMessage": "Represent the development perspective by finding the simplest safe implementation approach that preserves changeability and technical quality.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/development-amigo.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/development-amigo.rules.md"
        }
      ],
      "next": "three-amigos-join"
    },
    {
      "id": "testing-amigo",
      "kind": "Stage",
      "displayName": "Testing Amigo",
      "role": "Testing",
      "agent": "testing-amigo",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo"
      ],
      "outputs": [
        "testScenarios",
        "validationPlan"
      ],
      "customMessage": "Represent the testing perspective by clarifying scenarios, edge cases, regression risks, and the fastest credible validation plan.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/testing-amigo.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/testing-amigo.rules.md"
        }
      ],
      "next": "three-amigos-join"
    },
    {
      "id": "three-amigos-join",
      "kind": "Join",
      "displayName": "Three Amigos Join",
      "forkId": "three-amigos-fork",
      "next": "builder"
    },
    {
      "id": "builder",
      "kind": "Stage",
      "displayName": "Implementation",
      "role": "Implementation",
      "agent": "builder",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo",
        "node:development-amigo",
        "node:testing-amigo"
      ],
      "outputs": [
        "buildSummary",
        "validationEvidence"
      ],
      "customMessage": "Implement the smallest coherent change that satisfies the framed increment while preserving technical excellence through tests, simple design, and refactoring-minded choices.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/builder.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/builder.rules.md"
        }
      ],
      "next": "review-fork"
    },
    {
      "id": "review-fork",
      "kind": "Fork",
      "displayName": "Cross-Functional Review Fork",
      "joinNodeId": "review-join",
      "branches": [
        {
          "id": "solution-architecture",
          "nextNodeId": "solution-architect-reviewer"
        },
        {
          "id": "principal-engineering",
          "nextNodeId": "principal-engineer-reviewer"
        },
        {
          "id": "devops",
          "nextNodeId": "devops-engineer-reviewer"
        },
        {
          "id": "platform",
          "nextNodeId": "platform-engineer-reviewer"
        },
        {
          "id": "developer-evangelism",
          "nextNodeId": "developer-evangelist-reviewer"
        },
        {
          "id": "ux",
          "nextNodeId": "ux-designer-reviewer"
        }
      ]
    },
    {
      "id": "solution-architect-reviewer",
      "kind": "Stage",
      "displayName": "Solution Architecture Review",
      "role": "Review",
      "agent": "solution-architect-reviewer",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo",
        "node:development-amigo",
        "node:testing-amigo",
        "node:builder",
        "node:rebuilder"
      ],
      "outputs": [
        "solutionArchitectureReview"
      ],
      "customMessage": "Review every delivered change from a solution architecture perspective. Focus on boundaries, cohesion, coupling, long-term maintainability, and whether the implementation fits the intended system shape.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/solution-architect-reviewer.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/specialist-reviewer.rules.md"
        }
      ],
      "next": "review-join"
    },
    {
      "id": "principal-engineer-reviewer",
      "kind": "Stage",
      "displayName": "Principal Engineer Review",
      "role": "Review",
      "agent": "principal-engineer-reviewer",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo",
        "node:development-amigo",
        "node:testing-amigo",
        "node:builder",
        "node:rebuilder"
      ],
      "outputs": [
        "principalEngineerReview"
      ],
      "customMessage": "Review every delivered change from a principal engineer perspective. Focus on correctness, technical quality, test evidence, performance, resilience, and whether the implementation is the simplest sound solution.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/principal-engineer-reviewer.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/specialist-reviewer.rules.md"
        }
      ],
      "next": "review-join"
    },
    {
      "id": "devops-engineer-reviewer",
      "kind": "Stage",
      "displayName": "DevOps Review",
      "role": "Review",
      "agent": "devops-engineer-reviewer",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo",
        "node:development-amigo",
        "node:testing-amigo",
        "node:builder",
        "node:rebuilder"
      ],
      "outputs": [
        "devOpsReview"
      ],
      "customMessage": "Review every delivered change from a DevOps perspective. Focus on build reliability, deployment safety, operational readiness, telemetry, release risks, and feedback loops in automation.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/devops-engineer-reviewer.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/specialist-reviewer.rules.md"
        }
      ],
      "next": "review-join"
    },
    {
      "id": "platform-engineer-reviewer",
      "kind": "Stage",
      "displayName": "Platform Review",
      "role": "Review",
      "agent": "platform-engineer-reviewer",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo",
        "node:development-amigo",
        "node:testing-amigo",
        "node:builder",
        "node:rebuilder"
      ],
      "outputs": [
        "platformReview"
      ],
      "customMessage": "Review every delivered change from a platform engineering perspective. Focus on developer experience, runtime consistency, environment assumptions, scalability of tooling, and platform-level maintainability.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/platform-engineer-reviewer.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/specialist-reviewer.rules.md"
        }
      ],
      "next": "review-join"
    },
    {
      "id": "developer-evangelist-reviewer",
      "kind": "Stage",
      "displayName": "Developer Evangelist Review",
      "role": "Review",
      "agent": "developer-evangelist-reviewer",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo",
        "node:development-amigo",
        "node:testing-amigo",
        "node:builder",
        "node:rebuilder"
      ],
      "outputs": [
        "developerEvangelistReview"
      ],
      "customMessage": "Review every delivered change from a developer evangelist perspective. Focus on clarity, learnability, adoption friction, examples, naming, and whether the change helps other developers succeed.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/developer-evangelist-reviewer.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/specialist-reviewer.rules.md"
        }
      ],
      "next": "review-join"
    },
    {
      "id": "ux-designer-reviewer",
      "kind": "Stage",
      "displayName": "UX Review",
      "role": "Review",
      "agent": "ux-designer-reviewer",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo",
        "node:development-amigo",
        "node:testing-amigo",
        "node:builder",
        "node:rebuilder"
      ],
      "outputs": [
        "uxReview"
      ],
      "customMessage": "Review every delivered change from a UX design perspective. Focus on user flow, interaction clarity, accessibility, language, visual consistency, and whether the increment feels coherent for real users.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/ux-designer-reviewer.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/specialist-reviewer.rules.md"
        }
      ],
      "next": "review-join"
    },
    {
      "id": "review-join",
      "kind": "Join",
      "displayName": "Cross-Functional Review Join",
      "forkId": "review-fork",
      "next": "master-reviewer"
    },
    {
      "id": "master-reviewer",
      "kind": "Stage",
      "displayName": "Master Review",
      "role": "Review",
      "agent": "master-reviewer",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo",
        "node:development-amigo",
        "node:testing-amigo",
        "node:builder",
        "node:solution-architect-reviewer",
        "node:principal-engineer-reviewer",
        "node:devops-engineer-reviewer",
        "node:platform-engineer-reviewer",
        "node:developer-evangelist-reviewer",
        "node:ux-designer-reviewer",
        "node:rebuilder"
      ],
      "outputs": [
        "reviewVerdict",
        "reviewFindings"
      ],
      "customMessage": "Combine every specialist review into one master review. Deduplicate overlapping findings, preserve important disagreements, and produce one clear approval decision plus one consolidated set of builder instructions.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/master-reviewer.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/master-reviewer.rules.md"
        }
      ],
      "next": "review-decision"
    },
    {
      "id": "review-decision",
      "kind": "Decision",
      "displayName": "Review Decision",
      "role": "Decision",
      "agent": "decision",
      "decisionMode": "Rules",
      "ruleSet": "clean-agile-review",
      "decisionSourceNodeId": "master-reviewer",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo",
        "node:development-amigo",
        "node:testing-amigo",
        "node:builder",
        "node:master-reviewer",
        "node:rebuilder"
      ],
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/decision.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/decision.rules.md"
        }
      ],
      "choices": [
        {
          "id": "approve",
          "displayName": "Approve",
          "nextNodeId": "approved"
        },
        {
          "id": "rebuild",
          "displayName": "Rebuild",
          "nextNodeId": "rebuilder"
        },
        {
          "id": "stop",
          "displayName": "Stop",
          "nextNodeId": "stopped"
        }
      ]
    },
    {
      "id": "rebuilder",
      "kind": "Stage",
      "displayName": "Focused Rework",
      "role": "Rework",
      "agent": "rebuilder",
      "inputs": [
        "request",
        "node:increment-framing",
        "node:business-amigo",
        "node:development-amigo",
        "node:testing-amigo",
        "node:builder",
        "node:master-reviewer",
        "node:rebuilder"
      ],
      "outputs": [
        "reworkSummary",
        "updatedValidation"
      ],
      "customMessage": "Apply the smallest effective correction set needed to resolve review findings while preserving valid work and maintaining technical quality.",
      "assets": [
        {
          "kind": "agent-persona",
          "path": "agents/rebuilder.agent.md"
        },
        {
          "kind": "agent-rule",
          "path": "rules/agents/rebuilder.rules.md"
        }
      ],
      "next": "review-fork"
    },
    {
      "id": "approved",
      "kind": "Exit",
      "displayName": "Approved Exit",
      "exitStatus": "Approved"
    },
    {
      "id": "stopped",
      "kind": "Exit",
      "displayName": "Stopped Exit",
      "exitStatus": "Stopped"
    }
  ],
  "policy": {
    "decisionMode": "Rules",
    "maxReviewCycles": 2,
    "maxRebuilds": 1,
    "maxParallelism": 6,
    "maxNodeVisits": 12
  }
}
