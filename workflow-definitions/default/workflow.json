{
  "version": "2.3",
  "name": "Clean Agile Default Workflow",
  "defaultEntryPoint": "default",
  "entryPoints": [
    { "id": "default", "nodeId": "work-item-triage" },
    { "id": "planning", "nodeId": "work-item-triage" },
    { "id": "epic", "nodeId": "epic-planning" },
    { "id": "story-planning", "nodeId": "story-selection" },
    { "id": "architecture", "nodeId": "enterprise-architecture" },
    { "id": "three-amigos", "nodeId": "three-amigos-fork" },
    { "id": "architecture-review", "nodeId": "architecture-review-fork" },
    { "id": "three-amigos-review", "nodeId": "three-amigos-review-fork" },
    { "id": "build", "nodeId": "builder" },
    { "id": "review", "nodeId": "code-review-fork" },
    { "id": "code-review", "nodeId": "code-review-fork" }
  ],
  "sharedAssets": [
    { "kind": "theory", "path": "instructions/general/clean-agile.instructions.md" },
    { "kind": "theory", "path": "instructions/general/first-principles-thinking.instructions.md" },
    { "kind": "theory", "path": "instructions/general/chain-of-verification.instructions.md" },
    { "kind": "repository-instruction", "path": "instructions/repository/build-and-test.instructions.md" },
    { "kind": "repository-instruction", "path": "instructions/repository/repository-structure.instructions.md" },
    { "kind": "workflow-rule", "path": "rules/workflow/clean-agile.rules.md" },
    { "kind": "workflow-rule", "path": "rules/workflow/shared.rules.md" },
    { "kind": "workflow-rule", "path": "rules/workflow/repository-quality.rules.md" }
  ],
  "nodes": [
    {
      "id": "work-item-triage",
      "kind": "Stage",
      "displayName": "Work Item Triage",
      "role": "Planning",
      "agent": "epic-planner",
      "inputs": ["request"],
      "outputs": ["workItemStrategy", "epicSignal", "storySizingGuidance"],
      "customMessage": "Classify the request as a single story or an epic. Call out whether story slicing and stacked pull requests are required before implementation starts.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/epic-planner.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/epic-planner.rules.md" }
      ],
      "next": "work-item-shape-decision"
    },
    {
      "id": "work-item-shape-decision",
      "kind": "Decision",
      "displayName": "Work Item Shape Decision",
      "role": "Decision",
      "agent": "decision",
      "decisionMode": "Agent",
      "inputs": ["request", "node:work-item-triage"],
      "outputs": ["workItemRoutingChoice"],
      "customMessage": "Choose epic when the request must be decomposed into ordered stories before delivery; choose single-story when one reviewable story is enough.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/decision.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/decision.rules.md" }
      ],
      "choices": [
        { "id": "single-story", "displayName": "Single Story", "nextNodeId": "single-story-envelope" },
        { "id": "epic", "displayName": "Epic", "nextNodeId": "epic-planning" }
      ]
    },
    {
      "id": "single-story-envelope",
      "kind": "Stage",
      "displayName": "Single Story Envelope",
      "role": "Planning",
      "agent": "story-planner",
      "inputs": ["request", "node:work-item-triage"],
      "outputs": ["storyBacklog", "stackPlan"],
      "customMessage": "Create a one-story backlog and a stacked pull request plan for a request that fits a single small pull request.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/story-planner.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/story-planner.rules.md" }
      ],
      "next": "story-selection"
    },
    {
      "id": "epic-planning",
      "kind": "Stage",
      "displayName": "Epic Planning",
      "role": "Planning",
      "agent": "epic-planner",
      "responseTimeout": "00:10:00",
      "inputs": ["request", "node:work-item-triage"],
      "outputs": ["epicDefinition", "epicOutcomes", "epicGuardrails"],
      "customMessage": "Define the epic outcome, boundaries, and delivery guardrails before detailed story planning begins.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/epic-planner.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/epic-planner.rules.md" }
      ],
      "next": "story-stack-planning"
    },
    {
      "id": "story-stack-planning",
      "kind": "Stage",
      "displayName": "Story Stack Planning",
      "role": "Planning",
      "agent": "story-planner",
      "responseTimeout": "00:10:00",
      "inputs": ["request", "node:work-item-triage", "node:epic-planning"],
      "outputs": ["storyBacklog", "storyDependencies", "stackPlan"],
      "customMessage": "Decompose the epic into ordered stories sized for reviewable pull requests, normally around 600 changed lines total diff, with explicit stacked pull request guidance.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/story-planner.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/story-planner.rules.md" }
      ],
      "next": "story-selection"
    },
    {
      "id": "story-selection",
      "kind": "Stage",
      "displayName": "Story Selection",
      "role": "Planning",
      "agent": "story-planner",
      "inputs": ["request", "node:single-story-envelope", "node:epic-planning", "node:story-stack-planning", "node:github-sync", "node:github-poll"],
      "outputs": ["currentStory", "storyStackPosition", "storyBranchPlan"],
      "customMessage": "Select the next executable story. Start story 1 immediately for new epics, preserve dependency order, and emit the current story plus the suggested head/base branch plan for its stacked pull request.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/story-planner.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/story-planner.rules.md" }
      ],
      "next": "story-selection-decision"
    },
    {
      "id": "story-selection-decision",
      "kind": "Decision",
      "displayName": "Story Selection Decision",
      "role": "Decision",
      "agent": "decision",
      "decisionMode": "Agent",
      "inputs": ["request", "node:story-selection"],
      "outputs": ["storyRoutingChoice"],
      "customMessage": "Choose start-story when there is a current story ready for execution, epic-complete when all stories are complete, or stop when human intervention is required.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/decision.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/decision.rules.md" }
      ],
      "choices": [
        { "id": "start-story", "displayName": "Start Story", "nextNodeId": "increment-framing" },
        { "id": "epic-complete", "displayName": "Epic Complete", "nextNodeId": "approved" },
        { "id": "stop", "displayName": "Stop", "nextNodeId": "stopped" }
      ]
    },
    {
      "id": "increment-framing",
      "kind": "Stage",
      "displayName": "Increment Framing",
      "role": "Planning",
      "agent": "planner",
      "inputs": ["request", "node:story-selection"],
      "outputs": ["incrementFrame", "acceptanceSignals", "scopeGuardrails", "storyExecutionFrame"],
      "assets": [
        { "kind": "agent-persona", "path": "agents/planner.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/planner.rules.md" }
      ],
      "next": "architecture-scope-decision"
    },
    {
      "id": "architecture-scope-decision",
      "kind": "Decision",
      "displayName": "Architecture Scope Decision",
      "role": "Decision",
      "agent": "decision",
      "decisionMode": "Agent",
      "inputs": ["request", "node:story-selection", "node:increment-framing"],
      "outputs": ["architectureRoutingChoice"],
      "customMessage": "Choose architecture-needed for material system or code-shape change; choose skip-architecture for narrow docs, markdown, wording, or trivial work.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/decision.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/decision.rules.md" }
      ],
      "choices": [
        { "id": "architecture-needed", "displayName": "Architecture Needed", "nextNodeId": "enterprise-architecture" },
        { "id": "skip-architecture", "displayName": "Skip Architecture", "nextNodeId": "three-amigos-fork" }
      ]
    },
    {
      "id": "enterprise-architecture",
      "kind": "Stage",
      "displayName": "Enterprise Architecture",
      "role": "Architecture",
      "agent": "enterprise-architect",
      "responseTimeout": "00:10:00",
      "inputs": ["request", "node:story-selection", "node:increment-framing"],
      "outputs": ["enterpriseArchitectureScope", "enterpriseConstraints", "enterpriseDependencyMap"],
      "customMessage": "Define enterprise scope, boundaries, dependencies, and guardrails proportionately for the current story and epic context.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/enterprise-architect.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/enterprise-architect.rules.md" }
      ],
      "next": "solution-design"
    },
    {
      "id": "solution-design",
      "kind": "Stage",
      "displayName": "Solution Design",
      "role": "Architecture",
      "agent": "solution-architect",
      "responseTimeout": "00:10:00",
      "inputs": ["request", "node:story-selection", "node:increment-framing", "node:enterprise-architecture"],
      "outputs": ["solutionDesign", "architectureDecisionRecord"],
      "customMessage": "Create the implementable solution design for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/solution-architect.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/solution-architect.rules.md" }
      ],
      "next": "c4-system-context"
    },
    {
      "id": "c4-system-context",
      "kind": "Stage",
      "displayName": "C4 System Context",
      "role": "Architecture",
      "agent": "solution-architect",
      "responseTimeout": "00:10:00",
      "inputs": ["request", "node:story-selection", "node:solution-design"],
      "outputs": ["c4SystemContext"],
      "customMessage": "Produce the C4 system context output for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/solution-architect.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/solution-architect.rules.md" }
      ],
      "next": "c4-container"
    },
    {
      "id": "c4-container",
      "kind": "Stage",
      "displayName": "C4 Container",
      "role": "Architecture",
      "agent": "solution-architect",
      "responseTimeout": "00:10:00",
      "inputs": ["request", "node:story-selection", "node:solution-design", "node:c4-system-context"],
      "outputs": ["c4Container"],
      "customMessage": "Produce the C4 container output for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/solution-architect.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/solution-architect.rules.md" }
      ],
      "next": "c4-component"
    },
    {
      "id": "c4-component",
      "kind": "Stage",
      "displayName": "C4 Component",
      "role": "Architecture",
      "agent": "solution-architect",
      "responseTimeout": "00:10:00",
      "inputs": ["request", "node:story-selection", "node:solution-design", "node:c4-container"],
      "outputs": ["c4Component"],
      "customMessage": "Produce the C4 component output or explain why it adds little value for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/solution-architect.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/solution-architect.rules.md" }
      ],
      "next": "c4-code"
    },
    {
      "id": "c4-code",
      "kind": "Stage",
      "displayName": "C4 Code",
      "role": "Architecture",
      "agent": "solution-architect",
      "responseTimeout": "00:10:00",
      "inputs": ["request", "node:story-selection", "node:solution-design", "node:c4-component"],
      "outputs": ["c4Code"],
      "customMessage": "Produce the C4 code output or explain why it is not useful for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/solution-architect.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/solution-architect.rules.md" }
      ],
      "next": "architecture-review-fork"
    },
    {
      "id": "architecture-review-fork",
      "kind": "Fork",
      "displayName": "Architecture Review Fork",
      "joinNodeId": "architecture-review-join",
      "branches": [
        { "id": "solution-architecture", "nextNodeId": "architecture-solution-architect-reviewer" },
        { "id": "principal-engineering", "nextNodeId": "architecture-principal-engineer-reviewer" },
        { "id": "devops", "nextNodeId": "architecture-devops-engineer-reviewer" },
        { "id": "platform", "nextNodeId": "architecture-platform-engineer-reviewer" },
        { "id": "developer-evangelism", "nextNodeId": "architecture-developer-evangelist-reviewer" },
        { "id": "ux", "nextNodeId": "architecture-ux-designer-reviewer" }
      ]
    },
    {
      "id": "architecture-solution-architect-reviewer",
      "kind": "Stage",
      "displayName": "Architecture Solution Architecture Review",
      "role": "Review",
      "agent": "solution-architect-reviewer",
      "inputs": ["request", "node:story-selection", "node:solution-design", "node:c4-system-context", "node:c4-container", "node:c4-component", "node:c4-code"],
      "outputs": ["architectureSolutionArchitectureReview"],
      "customMessage": "Review architecture artifacts only for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/solution-architect-reviewer.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/specialist-reviewer.rules.md" }
      ],
      "next": "architecture-review-join"
    },
    {
      "id": "architecture-principal-engineer-reviewer",
      "kind": "Stage",
      "displayName": "Architecture Principal Engineer Review",
      "role": "Review",
      "agent": "principal-engineer-reviewer",
      "inputs": ["request", "node:story-selection", "node:solution-design", "node:c4-system-context", "node:c4-container", "node:c4-component", "node:c4-code"],
      "outputs": ["architecturePrincipalEngineerReview"],
      "customMessage": "Review architecture artifacts only for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/principal-engineer-reviewer.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/specialist-reviewer.rules.md" }
      ],
      "next": "architecture-review-join"
    },
    {
      "id": "architecture-devops-engineer-reviewer",
      "kind": "Stage",
      "displayName": "Architecture DevOps Review",
      "role": "Review",
      "agent": "devops-engineer-reviewer",
      "inputs": ["request", "node:story-selection", "node:solution-design", "node:c4-system-context", "node:c4-container", "node:c4-component", "node:c4-code"],
      "outputs": ["architectureDevOpsReview"],
      "customMessage": "Review architecture artifacts only for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/devops-engineer-reviewer.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/specialist-reviewer.rules.md" }
      ],
      "next": "architecture-review-join"
    },
    {
      "id": "architecture-platform-engineer-reviewer",
      "kind": "Stage",
      "displayName": "Architecture Platform Review",
      "role": "Review",
      "agent": "platform-engineer-reviewer",
      "inputs": ["request", "node:story-selection", "node:solution-design", "node:c4-system-context", "node:c4-container", "node:c4-component", "node:c4-code"],
      "outputs": ["architecturePlatformReview"],
      "customMessage": "Review architecture artifacts only for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/platform-engineer-reviewer.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/specialist-reviewer.rules.md" }
      ],
      "next": "architecture-review-join"
    },
    {
      "id": "architecture-developer-evangelist-reviewer",
      "kind": "Stage",
      "displayName": "Architecture Developer Evangelist Review",
      "role": "Review",
      "agent": "developer-evangelist-reviewer",
      "inputs": ["request", "node:story-selection", "node:solution-design", "node:c4-system-context", "node:c4-container", "node:c4-component", "node:c4-code"],
      "outputs": ["architectureDeveloperEvangelistReview"],
      "customMessage": "Review architecture artifacts only for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/developer-evangelist-reviewer.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/specialist-reviewer.rules.md" }
      ],
      "next": "architecture-review-join"
    },
    {
      "id": "architecture-ux-designer-reviewer",
      "kind": "Stage",
      "displayName": "Architecture UX Review",
      "role": "Review",
      "agent": "ux-designer-reviewer",
      "inputs": ["request", "node:story-selection", "node:solution-design", "node:c4-system-context", "node:c4-container", "node:c4-component", "node:c4-code"],
      "outputs": ["architectureUxReview"],
      "customMessage": "Review architecture artifacts only for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/ux-designer-reviewer.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/specialist-reviewer.rules.md" }
      ],
      "next": "architecture-review-join"
    },
    { "id": "architecture-review-join", "kind": "Join", "displayName": "Architecture Review Join", "forkId": "architecture-review-fork", "next": "architecture-master-reviewer" },
    {
      "id": "architecture-master-reviewer",
      "kind": "Stage",
      "displayName": "Architecture Master Review",
      "role": "Review",
      "agent": "master-reviewer",
      "inputs": [
        "request",
        "node:story-selection",
        "node:solution-design",
        "node:c4-system-context",
        "node:c4-container",
        "node:c4-component",
        "node:c4-code",
        "node:architecture-solution-architect-reviewer",
        "node:architecture-principal-engineer-reviewer",
        "node:architecture-devops-engineer-reviewer",
        "node:architecture-platform-engineer-reviewer",
        "node:architecture-developer-evangelist-reviewer",
        "node:architecture-ux-designer-reviewer"
      ],
      "outputs": ["architectureReviewVerdict", "architectureReviewFindings"],
      "customMessage": "Synthesize architecture review feedback for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/master-reviewer.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/master-reviewer.rules.md" }
      ],
      "next": "architecture-review-decision"
    },
    {
      "id": "architecture-review-decision",
      "kind": "Decision",
      "displayName": "Architecture Review Decision",
      "role": "Decision",
      "agent": "decision",
      "decisionMode": "Rules",
      "ruleSet": "clean-agile-review",
      "decisionSourceNodeId": "architecture-master-reviewer",
      "inputs": ["request", "node:architecture-master-reviewer"],
      "assets": [
        { "kind": "agent-persona", "path": "agents/decision.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/decision.rules.md" }
      ],
      "choices": [
        { "id": "approve", "displayName": "Approve", "nextNodeId": "three-amigos-fork" },
        { "id": "rework", "displayName": "Rework", "nextNodeId": "enterprise-architecture" },
        { "id": "stop", "displayName": "Stop", "nextNodeId": "stopped" }
      ]
    },
    {
      "id": "three-amigos-fork",
      "kind": "Fork",
      "displayName": "Three Amigos Fork",
      "joinNodeId": "three-amigos-join",
      "branches": [
        { "id": "business", "nextNodeId": "business-amigo" },
        { "id": "development", "nextNodeId": "development-amigo" },
        { "id": "testing", "nextNodeId": "testing-amigo" }
      ]
    },
    {
      "id": "business-amigo",
      "kind": "Stage",
      "displayName": "Business Amigo",
      "role": "Business",
      "agent": "business-amigo",
      "inputs": ["request", "node:story-selection", "node:increment-framing", "node:solution-design"],
      "outputs": ["businessOutcome", "acceptanceExamples"],
      "customMessage": "Clarify business outcomes and done-meaning for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/business-amigo.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/business-amigo.rules.md" }
      ],
      "next": "three-amigos-join"
    },
    {
      "id": "development-amigo",
      "kind": "Stage",
      "displayName": "Development Amigo",
      "role": "Development",
      "agent": "development-amigo",
      "inputs": ["request", "node:story-selection", "node:increment-framing", "node:solution-design", "node:c4-container", "node:c4-component", "node:c4-code"],
      "outputs": ["technicalApproach", "technicalRisks"],
      "customMessage": "Clarify the simplest safe implementation path for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/development-amigo.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/development-amigo.rules.md" }
      ],
      "next": "three-amigos-join"
    },
    {
      "id": "testing-amigo",
      "kind": "Stage",
      "displayName": "Testing Amigo",
      "role": "Testing",
      "agent": "testing-amigo",
      "inputs": ["request", "node:story-selection", "node:increment-framing", "node:solution-design", "node:c4-system-context", "node:c4-container"],
      "outputs": ["testScenarios", "validationPlan"],
      "customMessage": "Clarify scenarios, risks, and validation for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/testing-amigo.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/testing-amigo.rules.md" }
      ],
      "next": "three-amigos-join"
    },
    { "id": "three-amigos-join", "kind": "Join", "displayName": "Three Amigos Join", "forkId": "three-amigos-fork", "next": "three-amigos-review-fork" },
    {
      "id": "three-amigos-review-fork",
      "kind": "Fork",
      "displayName": "Three Amigos Review Fork",
      "joinNodeId": "three-amigos-review-join",
      "branches": [
        { "id": "solution-architecture", "nextNodeId": "three-amigos-solution-architect-reviewer" },
        { "id": "principal-engineering", "nextNodeId": "three-amigos-principal-engineer-reviewer" },
        { "id": "devops", "nextNodeId": "three-amigos-devops-engineer-reviewer" },
        { "id": "platform", "nextNodeId": "three-amigos-platform-engineer-reviewer" },
        { "id": "developer-evangelism", "nextNodeId": "three-amigos-developer-evangelist-reviewer" },
        { "id": "ux", "nextNodeId": "three-amigos-ux-designer-reviewer" }
      ]
    },
    {
      "id": "three-amigos-solution-architect-reviewer",
      "kind": "Stage",
      "displayName": "Three Amigos Solution Architecture Review",
      "role": "Review",
      "agent": "solution-architect-reviewer",
      "inputs": ["request", "node:story-selection", "node:solution-design", "node:business-amigo", "node:development-amigo", "node:testing-amigo"],
      "outputs": ["threeAmigosSolutionArchitectureReview"],
      "customMessage": "Review Three Amigos artifacts only for the selected story.",
      "assets": [
        { "kind": "agent-persona", "path": "agents/solution-architect-reviewer.agent.md" },
        { "kind": "agent-rule", "path": "rules/agents/specialist-reviewer.rules.md" }
      ],
      "next": "three-amigos-review-join"
    },
    {
      "id": "three-amigos-principal-engineer-reviewer",
      "kind": "Stage",
      "displayName": "Three Amigos Principal Engineer Review",
